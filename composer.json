{
    "name": "rimba/boleh",
    "description": "Access control layer combining roles, permissions, and policies (RBAC + ABAC).",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "rimba/asas": "^1.0",
        "spatie/laravel-permission": "^7.3"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rimba\\Can\\CanServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
           "Rimba\\Can\\": "src/"
        }
    },
    "minimum-stability": "alpha",
    "prefer-stable": true
}
